{
  "name": "naval",
  "version": "0.1.0",
  "description": "Unofficial 79-skill Naval pack with optional setup, memory, reviews, and scorecards.",
  "private": true,
  "type": "module",
  "main": ".opencode/plugins/naval.js",
  "pi": {
    "extensions": [
      "./.pi/extensions/naval.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "homepage": "https://github.com/thepraggyverse/naval",
  "repository": "https://github.com/thepraggyverse/naval",
  "license": "MIT",
  "scripts": {
    "docs:skills": "python3 scripts/generate_skill_docs.py",
    "validate": "python3 scripts/validate_public.py && python3 scripts/check_coverage.py && python3 scripts/validate_direct_install.py && python3 scripts/smoke_install.py",
    "export:direct": "python3 scripts/export_direct_install.py --output dist/naval-direct-install --force",
    "install:local": "python3 scripts/install_local.py --marketplace --symlink-skills",
    "smoke:install": "python3 scripts/smoke_install.py",
    "smoke:live": "python3 scripts/smoke_install.py --codex --live"
  }
}
